ENVIRONMENT=development
HTTP_SERVER_ADDRESS=0.0.0.0:8080
GRPC_SERVER_ADDRESS=0.0.0.0:9090
DB_SOURCE=postgresql://root:supersecret@localhost:5432/hias_db?sslmode=disable
REDIS_URL=redis://localhost:6379
AWS_REGION=af-south-1
AWS_ENDPOINT_URL=http://localhost:4566
TOKEN_SYMMETRIC_KEY=12345678901234567890123456789012
ACCESS_TOKEN_DURATION=15m
REFRESH_TOKEN_DURATION=24h
COOKIE_DOMAIN=localhost
ALLOWED_ORIGINS=http://localhost:3000
DASHBOARD_URL=http://localhost:3000
AWS_S3_BUCKET=hias-documents
AWS_S3_REGION=af-south-1
AWS_SQS_DOCUMENT_PROCESSING_QUEUE_URL=http://localhost:4566/000000000000/document-processing
AWS_SQS_EXTRACTION_RESULTS_QUEUE_URL=http://localhost:4566/000000000000/extraction-results
AWS_SQS_CLAIM_PROCESSING_QUEUE_URL=http://localhost:4566/000000000000/claim-processing
AWS_SQS_PAYMENT_EVENTS_QUEUE_URL=http://localhost:4566/000000000000/payment-events
AWS_SQS_NOTIFICATION_EVENTS_QUEUE_URL=http://localhost:4566/000000000000/notification-events
CONSUMER_TYPE=sqs
QUEUE_MANAGER_TYPE=watermill
WATERMILL_WAIT_TIME_SECONDS=20
WATERMILL_MAX_MESSAGES=10
WATERMILL_VISIBILITY_TIMEOUT=30s
MPESA_ENVIRONMENT=sandbox
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=http://localhost:8080/api/v1/payments/webhook/mpesa
SCHEDULER_ENABLED=true
BILLING_CYCLE_SCHEDULE=0 0 1 * *
PAYMENT_REMINDER_SCHEDULE=0 8 * * *
POLICY_LAPSE_SCHEDULE=0 1 * * *
PREAUTH_EXPIRY_SCHEDULE=0 2 * * *
REMITTANCE_CYCLE_SCHEDULE=0 0 * * 1
PAYMENT_RETRY_SCHEDULE=0 */4 * * *
RECONCILIATION_SCHEDULE=0 2 * * *
NOTIFICATION_RETRY_SCHEDULE=*/30 * * * *
SMS_SENDER_ID=HIAS
SES_FROM_EMAIL=noreply@hias.co.ke
WEBSOCKET_MAX_CONNECTIONS_PER_USER=5
WEBSOCKET_MAX_TOTAL_CONNECTIONS=1000
WEBSOCKET_READ_TIMEOUT=60s
WEBSOCKET_WRITE_TIMEOUT=10s
WEBSOCKET_PING_INTERVAL=30s
WEBSOCKET_PONG_TIMEOUT=10s
WEBSOCKET_CLIENT_HEARTBEAT_TIMEOUT=90s
WEBSOCKET_ENABLE_METRICS=true
WEBSOCKET_ALLOWED_ORIGINS=http://localhost:3000
SSE_MAX_CONNECTIONS=500
SSE_MAX_CONNECTIONS_PER_USER=3
SSE_READ_TIMEOUT=60s
SSE_WRITE_TIMEOUT=10s
SSE_IDLE_TIMEOUT=300s
SSE_ENABLE_METRICS=true
SSE_ENABLE_HEARTBEAT=true
SSE_HEARTBEAT_INTERVAL=30s
SSE_CLEANUP_INTERVAL=60s
