```go
func (s *adjudicatorServiceImpl) evaluateAdjudicationRule(ctx context.Context, rule *entity.AdjudicationRule, claim *entity.Claim, lineItems []*entity.ClaimLineItem, payableAmount int64) entity.RuleResult {
    switch shared.AdjudicationRuleType(rule.RuleType) {
    case shared.AdjudicationRuleTypeAmountThreshold:
        // Parameters: {"max_amount": 5000000}
        var params struct {
            MaxAmount int64 `json:"max_amount"`
        }
        if err := json.Unmarshal(rule.Parameters, &params); err == nil && params.MaxAmount > 0 {
            if claim.TotalAmount > params.MaxAmount {
                return entity.RuleResult{
                    Category: string(shared.RuleCategoryLimits),
                    Rule:     rule.Name,
                    Result:   string(shared.RuleResultFlag),
                    Details:  fmt.Sprintf("Claim amount %d exceeds auto-approval threshold %d — requires manual review", claim.TotalAmount, params.MaxAmount),
                }
            }
        }

    case shared.AdjudicationRuleTypeFrequencyLimit:
        // Parameters: {"max_claims_per_month": 3}
        var params struct {
            MaxClaimsPerMonth int `json:"max_claims_per_month"`
        }
        if err := json.Unmarshal(rule.Parameters, &params); err == nil && params.MaxClaimsPerMonth > 0 {
            recentClaims, _ := s.claimRepo.CountByMemberThisMonth(ctx, claim.MemberID)
            if int(recentClaims) >= params.MaxClaimsPerMonth {
                return entity.RuleResult{
                    Category: string(shared.RuleCategoryFraud),
                    Rule:     rule.Name,
                    Result:   string(shared.RuleResultFlag),
                    Details:  fmt.Sprintf("Member has %d claims this month (limit: %d) — requires manual review", recentClaims, params.MaxClaimsPerMonth),
                }
            }
        }

    case shared.AdjudicationRuleTypeAutoApprove:
        // Parameters: {"max_amount": 1000000}  — auto-approve claims below this
        var params struct {
            MaxAmount int64 `json:"max_amount"`
        }
        if err := json.Unmarshal(rule.Parameters, &params); err == nil && params.MaxAmount > 0 {
            if claim.TotalAmount <= params.MaxAmount {
                return entity.RuleResult{
                    Category: string(shared.RuleCategoryLimits),
                    Rule:     rule.Name,
                    Result:   string(shared.RuleResultPass),
                    Details:  fmt.Sprintf("Auto-approved: amount %d is within auto-approval limit %d", claim.TotalAmount, params.MaxAmount),
                }
            }
        }
    }

    return entity.RuleResult{
        Category: string(shared.RuleCategoryLimits),
        Rule:     rule.Name,
        Result:   string(shared.RuleResultPass),
        Details:  "Rule evaluated — no action needed",
    }
}
```

