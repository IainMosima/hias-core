func (s *claimServiceImpl) evaluateEscalationRules(rules []*entity.EscalationRule, claim *entity.Claim, fraudFlags []*entity.FraudFlag) (bool, string, string) {
    for _, rule := range rules {
        switch shared.EscalationConditionType(rule.ConditionType) {
        case shared.EscalationConditionAmountExceeds:
            if rule.ThresholdAmount > 0 && claim.TotalAmount > rule.ThresholdAmount {
                return true, rule.EscalationRole, fmt.Sprintf("Amount %d exceeds threshold %d", claim.TotalAmount, rule.ThresholdAmount)
            }
        case shared.EscalationConditionFraudFlag:
            if len(fraudFlags) > 0 {
                // Check for high/critical severity fraud flags
                for _, f := range fraudFlags {
                    if f.Severity == string(shared.FraudSeverityHigh) || f.Severity == string(shared.FraudSeverityCritical) {
                        return true, rule.EscalationRole, fmt.Sprintf("High/critical fraud flag: %s", f.FlagType)
                    }
                }
            }
        case shared.EscalationConditionManualReview:
            if claim.Status == string(shared.ClaimStatusManualReview) {
                return true, rule.EscalationRole, "Claim requires manual review"
            }
        }
    }
    return false, "", ""
}
```

