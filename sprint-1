```go
// Calculate premium adjustment based on endorsement type
pol, polErr := s.policyRepo.GetByID(ctx, endorsement.PolicyID)
if polErr != nil {
    return schema.NewServiceErrorResponse[policySchema.EndorsementResponse](http.StatusInternalServerError, "Failed to get policy for premium calculation", polErr)
}

switch endorsement.EndorsementType {
case string(shared.EndorsementTypeAddMember):
    // Pro-rate: calculate per-member premium for remaining days
    if s.premiumRuleSvc != nil {
        // Get current member count
        members, _ := s.memberSvc.ListByPolicy(ctx, endorsement.PolicyID)
        currentCount := 0
        if members.Error == nil {
            currentCount = len(members.Data)
        }
        // Calculate premium for current+1 members vs current members
        newPremResp := s.premiumRuleSvc.CalculatePremiumWithMembers(ctx, pol.PlanID, currentCount+1, nil)
        if newPremResp.Error == nil && newPremResp.Data > pol.PremiumAmount {
            fullDelta := newPremResp.Data - pol.PremiumAmount
            // Pro-rate for remaining policy period
            remainingDays := pol.EndDate.Sub(endorsement.EffectiveDate).Hours() / 24
            totalDays := pol.EndDate.Sub(pol.StartDate).Hours() / 24
            if totalDays > 0 {
                endorsement.PremiumAdjustment = int64(float64(fullDelta) * remainingDays / totalDays)
            } else {
                endorsement.PremiumAdjustment = fullDelta
            }
        }
    }

case string(shared.EndorsementTypeRemoveMember):
    // Pro-rate refund: calculate per-member premium for remaining days
    if s.premiumRuleSvc != nil {
        members, _ := s.memberSvc.ListByPolicy(ctx, endorsement.PolicyID)
        currentCount := 0
        if members.Error == nil {
            currentCount = len(members.Data)
        }
        if currentCount > 1 {
            newPremResp := s.premiumRuleSvc.CalculatePremiumWithMembers(ctx, pol.PlanID, currentCount-1, nil)
            if newPremResp.Error == nil && newPremResp.Data < pol.PremiumAmount {
                fullDelta := newPremResp.Data - pol.PremiumAmount // negative = refund
                remainingDays := pol.EndDate.Sub(endorsement.EffectiveDate).Hours() / 24
                totalDays := pol.EndDate.Sub(pol.StartDate).Hours() / 24
                if totalDays > 0 {
                    endorsement.PremiumAdjustment = int64(float64(fullDelta) * remainingDays / totalDays)
                } else {
                    endorsement.PremiumAdjustment = fullDelta
                }
            }
        }
    }
}
```

