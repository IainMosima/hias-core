## TASK 3: Implement M-Pesa Webhook Processing

**Problem:** `PaymentService.ProcessWebhook()` at `services/billing/payment_service_impl.go:68-70` is a stub returning `"processed"`. The payment is never confirmed, and reconciliation is a passthrough.

**Files to modify:**
- `services/billing/payment_service_impl.go`
- `domains/billing/schema/billing_request.go` (add webhook request type if missing)

**Implementation:**

1. Replace the `ProcessWebhook` method with actual logic:

```go
func (s *paymentServiceImpl) ProcessWebhook(ctx context.Context, data interface{}) *schema.ServiceResponse[string] {
    // Parse the webhook data — expect a map from the handler
    webhookData, ok := data.(map[string]interface{})
    if !ok {
        return schema.NewServiceErrorResponse[string](http.StatusBadRequest, "Invalid webhook data format", nil)
    }

    // Extract M-Pesa fields
    resultCode, _ := webhookData["ResultCode"].(float64)
    mpesaRef, _ := webhookData["MpesaReceiptNumber"].(string)
    transactionRef, _ := webhookData["AccountReference"].(string)
    amountFloat, _ := webhookData["Amount"].(float64)
    amountCents := int64(amountFloat * 100) // Convert to cents

    if transactionRef == "" {
        return schema.NewServiceErrorResponse[string](http.StatusBadRequest, "Missing AccountReference in webhook", nil)
    }

    // Find payment by reference number
    payment, err := s.paymentRepo.GetByReference(ctx, transactionRef)
    if err != nil {
        return schema.NewServiceErrorResponse[string](http.StatusNotFound, fmt.Sprintf("Payment not found for reference: %s", transactionRef), err)
    }

    if int(resultCode) != 0 {
        // Payment failed
        s.paymentRepo.UpdateStatus(ctx, payment.ID, string(shared.PaymentStatusFailed))
        return schema.NewServiceResponse("payment_failed", http.StatusOK, "Payment failed — status updated")
    }

    // Verify amount matches (allow small variance for currency conversion)
    if amountCents > 0 && amountCents != payment.Amount {
        // Amount mismatch — flag for manual reconciliation but still confirm
        payment.Notes = fmt.Sprintf("Amount mismatch: expected %d, received %d", payment.Amount, amountCents)
    }

    // Update payment with M-Pesa receipt
    payment.ExternalRef = mpesaRef
    payment.Status = string(shared.PaymentStatusConfirmed)
    payment.PaidAt = timePtr(time.Now())

    updated, err := s.paymentRepo.Update(ctx, payment)
    if err != nil {
        return schema.NewServiceErrorResponse[string](http.StatusInternalServerError, "Failed to update payment", err)
    }

    // Auto-reconcile if invoice is linked
    if updated.InvoiceID != uuid.Nil && s.invoiceRepo != nil {
        s.invoiceRepo.UpdateStatus(ctx, updated.InvoiceID, string(shared.InvoiceStatusPaid))
    }

    return schema.NewServiceResponse("confirmed", http.StatusOK, fmt.Sprintf("Payment confirmed: %s", mpesaRef))
}

func timePtr(t time.Time) *time.Time {
    return &t
}
```

2. Update the `ReconcilePayment` to do actual reconciliation:

```go
func (s *paymentServiceImpl) ReconcilePayment(ctx context.Context, paymentID uuid.UUID) *schema.ServiceResponse[billingSchema.PaymentResponse] {
    payment, err := s.paymentRepo.GetByID(ctx, paymentID)
    if err != nil {
        return schema.NewServiceErrorResponse[billingSchema.PaymentResponse](http.StatusNotFound, "Payment not found", err)
    }

    if payment.Status != string(shared.PaymentStatusConfirmed) {
        return schema.NewServiceErrorResponse[billingSchema.PaymentResponse](
            http.StatusBadRequest,
            fmt.Sprintf("Cannot reconcile payment in %s status; must be CONFIRMED", payment.Status),
            nil,
        )
    }

    payment.Status = string(shared.PaymentStatusReconciled)
    updated, err := s.paymentRepo.Update(ctx, payment)
    if err != nil {
        return schema.NewServiceErrorResponse[billingSchema.PaymentResponse](http.StatusInternalServerError, "Failed to reconcile payment", err)
    }

    return schema.NewServiceResponse(billingSchema.ToPaymentResponse(updated), http.StatusOK, "Payment reconciled")
}
```

