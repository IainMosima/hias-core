# ============================================================
# HIAS Core — single env file for Docker Compose
# Copy to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Compose: local postgres credentials ---
# Used by the postgres, migrate, and healthcheck services.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=supersecret
POSTGRES_DB=hias_db

# --- Compose: AWS credentials (optional — only needed for SQS / S3 / SES) ---
# Leave blank for purely local development. The app boots and serves traffic without these.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Compose: frontend → backend URL ---
# Default routes to the local hias-core container (server-side / Next.js proxy).
# To use the hosted IBM Cloud demo backend instead, change to:
#   API_BASE_URL=https://hias-core-health-information-administration-system.apps.itz-cnnndf.infra01-lb.dal14.techzone.ibm.com/
API_BASE_URL=http://hias-core:8080

# ============================================================
# App config (read by hias-core at startup via env_file)
# ============================================================

# --- Core ---
ENVIRONMENT=development
HTTP_SERVER_ADDRESS=0.0.0.0:8080
GRPC_SERVER_ADDRESS=0.0.0.0:9090

# --- Database --- (required — app will not start without this)
# Defaults to the local compose postgres service. Change to Supabase/RDS for production.
DB_SOURCE_HIAS=postgres://postgres:supersecret@postgres:5432/hias_db?sslmode=disable

# --- Redis ---
# Defaults to the local compose redis service.
REDIS_URL=redis://redis:6379

# --- AWS ---
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=

# --- Cognito ---
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_REDIRECT_URI=
COGNITO_DOMAIN=
COGNITO_USER_POOL_ID=

# --- Auth / PASETO --- (required — must be exactly 32 characters, replace before deploying)
TOKEN_SYMMETRIC_KEY=12345678901234567890123456789012
ACCESS_TOKEN_DURATION=15m
REFRESH_TOKEN_DURATION=24h
COOKIE_DOMAIN=localhost

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000
DASHBOARD_URL=http://localhost:3000

# --- S3 ---
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
AWS_S3_CDN_DOMAIN=
AWS_S3_MAX_FILE_SIZE=10485760
AWS_S3_ALLOWED_TYPES=image/jpeg,image/png,application/pdf

# --- SQS Queue URLs ---
AWS_SQS_DOCUMENT_PROCESSING_QUEUE_URL=
AWS_SQS_EXTRACTION_RESULTS_QUEUE_URL=
AWS_SQS_CLAIM_PROCESSING_QUEUE_URL=
AWS_SQS_PAYMENT_EVENTS_QUEUE_URL=
AWS_SQS_NOTIFICATION_EVENTS_QUEUE_URL=

# --- Watermill / Consumer ---
CONSUMER_TYPE=sqs
QUEUE_MANAGER_TYPE=sqs
WATERMILL_WAIT_TIME_SECONDS=20
WATERMILL_MAX_MESSAGES=10
WATERMILL_VISIBILITY_TIMEOUT=30s

# --- M-Pesa ---
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_CALLBACK_URL=
MPESA_ENVIRONMENT=sandbox

# --- IPRS ---
IPRS_BASE_URL=
IPRS_API_KEY=

# --- SMART / Slade360 ---
SMART_BASE_URL=
SMART_API_KEY=
SMART_API_SECRET=
SMART_FACILITY_CODE=

# --- Bank ---
BANK_BASE_URL=
BANK_API_KEY=
BANK_ACCOUNT_NO=

# --- SMS (Africa's Talking) ---
SMS_API_KEY=
SMS_USERNAME=
SMS_SENDER_ID=

# --- SNS / SES ---
SNS_TOPIC_ARN=
NOTIFICATION_TOPIC_ARN=
SES_FROM_EMAIL=

# --- WebSocket ---
WEBSOCKET_MAX_CONNECTIONS_PER_USER=5
WEBSOCKET_MAX_TOTAL_CONNECTIONS=10000
WEBSOCKET_READ_TIMEOUT=60s
WEBSOCKET_WRITE_TIMEOUT=60s
WEBSOCKET_PING_INTERVAL=30s
WEBSOCKET_PONG_TIMEOUT=10s
WEBSOCKET_CLIENT_HEARTBEAT_TIMEOUT=120s
WEBSOCKET_ENABLE_METRICS=false
WEBSOCKET_ALLOWED_ORIGINS=*

# --- SSE ---
SSE_MAX_CONNECTIONS=10000
SSE_MAX_CONNECTIONS_PER_USER=5
SSE_READ_TIMEOUT=60s
SSE_WRITE_TIMEOUT=60s
SSE_IDLE_TIMEOUT=300s
SSE_ENABLE_METRICS=false
SSE_ENABLE_HEARTBEAT=true
SSE_HEARTBEAT_INTERVAL=30s
SSE_CLEANUP_INTERVAL=60s

# --- Scheduler ---
SCHEDULER_ENABLED=false
BILLING_CYCLE_SCHEDULE=0 0 1 * *
PAYMENT_REMINDER_SCHEDULE=0 8 * * *
POLICY_LAPSE_SCHEDULE=0 1 * * *
PREAUTH_EXPIRY_SCHEDULE=0 * * * *
REMITTANCE_CYCLE_SCHEDULE=0 0 1 * *
PAYMENT_RETRY_SCHEDULE=0 */4 * * *
RECONCILIATION_SCHEDULE=0 2 * * *
NOTIFICATION_RETRY_SCHEDULE=*/15 * * * *
REPORT_DISTRIBUTION_SCHEDULE=0 6 1 * *
REPORT_CLEANUP_SCHEDULE=0 3 * * 0
