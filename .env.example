# Local postgres credentials — consumed by docker-compose.yml variable substitution.
# Defaults match the compose healthcheck and migrate service. Change together if you rotate.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=supersecret
POSTGRES_DB=hias_db

# AWS credentials passed through to the hias-core container.
# Leave blank if you are not using SQS / S3 / SES locally.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
